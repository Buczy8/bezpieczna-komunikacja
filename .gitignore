
# Python - pliki tymczasowe i skompilowane
__pycache__/
*.py[cod]
*$py.class
*.so

# Środowiska wirtualne
venv/
env/
.env/
.venv/
Pipfile.lock
requirements.txt.log

# Zmienne środowiskowe i sekrety
.env
.flaskenv

# Wygenerowane artefakty PKI (sekrety i materiały runtime)
Certs/**/*.key
Certs/**/*.csr
Certs/**/*.srl
Certs/**/*.crt
Certs/**/*.pem
Certs/**/*.der
Certs/**/*.p12
Certs/**/*.pfx

# Jawnie zostawiamy szablony i dokumentację PKI
!Certs/**/*.cnf
!Certs/**/README.md
!Certs/**/*.example

# Pliki IDE i edytorów
.vscode/
.idea/
*.swp

# Systemowe pliki
.DS_Store
Thumbs.db